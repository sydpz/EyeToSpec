{
  "name": "Search Home",
  "description": "New absolute-coordinate contract demo. A big canvas workspace holds a phoneFrame element (the viewport) plus the search-page pieces, each placed by absolute normalized coords + depth. EyeToSpec paints low depth first; the runtime block is game-only and ignored here.",
  "canvas": { "width": 2000, "height": 2000 },
  "elements": {
    "phoneFrame": {
      "type": "frame", "depth": 0,
      "cx": 0.5, "cy": 0.5, "w": 0.36, "h": 0.64,
      "detail": { "aspect": "720x1280" }
    },
    "logo": {
      "type": "image", "depth": 10,
      "cx": 0.44, "cy": 0.28, "w": 0.16,
      "detail": { "tex": "logo.svg" }
    },
    "searchbar": {
      "type": "image", "depth": 10,
      "cx": 0.53, "cy": 0.38, "w": 0.25,
      "detail": { "tex": "searchbar.svg" }
    },
    "btn_search": {
      "type": "image", "depth": 20,
      "cx": 0.43, "cy": 0.47, "w": 0.11,
      "detail": { "tex": "button.svg" }
    },
    "label_search": {
      "type": "text", "depth": 30,
      "cx": 0.56, "cy": 0.50, "w": 0.10, "h": 0.02,
      "detail": { "text": "Search", "fontSize": 8, "color": "#3c4043", "align": "center" }
    }
  },
  "runtime": {
    "fitMode": "elastic",
    "anchors": { "logo": "baseline" }
  }
}
