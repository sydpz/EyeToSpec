# EyeToSpec

# Config packs are local working data, not source.
# Only the reference pack `search-home` is tracked; ignore everything else.
/config/*
!/config/search-home
!/config/search-home/**

# Exported coordinates are user output, not source.
# Keep the folder, ignore its contents.
/output/*
!/output/.gitkeep

# Superpowers skill symlink (local dev tooling, not part of the project)
/.trae/

# OS / editor cruft
.DS_Store
._*
Thumbs.db
*.swp
.vscode/
.idea/

# Python
__pycache__/
*.py[cod]
